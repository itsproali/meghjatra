# Supabase (Project Settings → API)
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# তোমার ম্যানেজার পাসওয়ার্ড (যা দিয়ে শুধু তুমি হিসাব এডিট করবে)
OWNER_PASSWORD=1234

# Cloudflare R2 
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-cloudflare-access-key-id
R2_SECRET_ACCESS_KEY=your-cloudflare-secret-access-key
R2_BUCKET=your-cloudflare-bucket-name
R2_PUBLIC_URL=https://your-cloudflare-bucket-name.r2.cloudflarestorage.com